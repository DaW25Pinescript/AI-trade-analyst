# AI Analyst — API Keys
# Copy this file to .env and fill in the keys you have.
# Leave blank any you don't have — those analysts will run in manual mode.
# Never commit .env to version control.
#
# ── Production: Secrets Manager ──────────────────────────────────────────────
# Instead of .env files, inject secrets via your platform's secret manager.
# Supported patterns (no code changes required — all keys are read from env):
#
#   AWS Secrets Manager:
#     Store keys in a single secret (JSON), then inject at container start:
#       aws secretsmanager get-secret-value --secret-id ai-trade-analyst \
#         --query SecretString --output text | jq -r 'to_entries[]|"\(.key)=\(.value)"' > .env
#     Or use ECS/EKS native secret injection (see docs/secrets_manager.md).
#
#   GCP Secret Manager:
#     gcloud secrets versions access latest --secret=ai-trade-analyst \
#       --format='get(payload.data)' | base64 -d > .env
#     Or use Cloud Run / GKE secret volume mounts.
#
#   HashiCorp Vault:
#     vault kv get -format=json secret/ai-trade-analyst \
#       | jq -r '.data.data|to_entries[]|"\(.key)=\(.value)"' > .env
#     Or use Vault Agent sidecar for automatic rotation.
#
# See docs/secrets_manager.md for detailed setup instructions.

# Anthropic (Claude Sonnet, Claude Haiku)
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o, GPT-4o-mini)
OPENAI_API_KEY=

# Google (Gemini 1.5 Pro)
GOOGLE_API_KEY=

# xAI (Grok Vision, Grok-3)
XAI_API_KEY=

# ── CORS & Deployment ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the browser app.
# Leave blank for local development (defaults to localhost:8080).
# Set to your production domain(s) when deploying:
#   ALLOWED_ORIGINS=https://app.example.com
ALLOWED_ORIGINS=

# ── Macro Risk Officer (Track D) ──────────────────────────────────────────────
# Required for MRO Phase 1. Both keys needed for full context (Finnhub for
# event calendar surprises, FRED for macro series momentum).
# Get Finnhub key: https://finnhub.io/dashboard
# Get FRED key:    https://fred.stlouisfed.org/docs/api/api_key.html

FINNHUB_API_KEY=
FRED_API_KEY=

# ── LLM Proxy — OpenAI-compatible endpoint for local Claude routing ─────
OPENAI_BASE_URL=http://127.0.0.1:8317/v1
OPENAI_API_KEY=your_proxy_key_here
OPENAI_MODEL=claude-sonnet-4-6
OPENAI_LIGHT_MODEL=claude-3-5-haiku-20241022
OPENAI_HEAVY_MODEL=claude-opus-4-6

# Provider label for logs and config clarity
MODEL_BACKEND=openai_compatible
MODEL_PROVIDER_LABEL=claude_max_proxy

# Proxy overrides (used by config_loader.py to override llm_routing.yaml values)
CLAUDE_PROXY_BASE_URL=http://127.0.0.1:8317/v1
LOCAL_LLM_PROXY_API_KEY=

# Backend selector — use litellm (default) or claude_code_api
AI_ANALYST_LLM_BACKEND=litellm
