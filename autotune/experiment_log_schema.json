{
  "meta": {
    "version": "v1.0",
    "description": "Schema for experiment_log.jsonl — append-only, one JSON object per line, one line per iteration",
    "file_path": "logs/experiment_log.jsonl",
    "notes": "This file defines the schema. The actual log is append-only JSONL in logs/. This is reference documentation — the runner code is the source of truth."
  },
  "schema": {
    "experiment_id": {
      "type": "string",
      "format": "{session_id}_EXP{NNN}",
      "example": "structure_short_20260320_143200_EXP001",
      "description": "Unique experiment identifier, session-scoped sequential"
    },
    "instance_id": {
      "type": "string",
      "enum": ["structure_short", "structure_medium"],
      "description": "Which lens instance was being tuned"
    },
    "timestamp_utc": {
      "type": "string",
      "format": "ISO 8601",
      "description": "When this iteration completed"
    },
    "session_id": {
      "type": "string",
      "format": "{instance_id}_{YYYYMMDD_HHMMSS}",
      "description": "Groups iterations within one tuning session"
    },
    "iteration": {
      "type": "integer",
      "description": "1-indexed iteration number within this session"
    },
    "change": {
      "parameter": {
        "type": "string",
        "description": "Which parameter was changed"
      },
      "old_value": {
        "type": "number",
        "description": "Value before this iteration"
      },
      "new_value": {
        "type": "number",
        "description": "Value proposed for this iteration"
      }
    },
    "params_snapshot": {
      "type": "object",
      "description": "Full parameter state used for this evaluation run"
    },
    "metrics": {
      "total_calls": {
        "type": "integer",
        "description": "Bullish + bearish calls (excluding ranging and lens errors)"
      },
      "confirmed": {
        "type": "integer"
      },
      "invalidated": {
        "type": "integer"
      },
      "unresolved": {
        "type": "integer"
      },
      "resolved_calls": {
        "type": "integer",
        "description": "confirmed + invalidated (stored explicitly)"
      },
      "accuracy": {
        "type": "float",
        "description": "confirmed / resolved_calls",
        "range": "0.0–1.0"
      },
      "resolve_rate": {
        "type": "float",
        "description": "resolved_calls / total_calls",
        "range": "0.0–1.0"
      }
    },
    "diagnostics": {
      "ranging_calls": {
        "type": "integer"
      },
      "ranging_pct": {
        "type": "float",
        "description": "ranging_calls / (total_calls + ranging_calls + lens_errors)"
      },
      "bullish_calls": {
        "type": "integer"
      },
      "bearish_calls": {
        "type": "integer"
      },
      "lens_errors": {
        "type": "integer",
        "description": "Times lens returned failed or had missing/invalid direction"
      },
      "mean_atr_at_call": {
        "type": "float"
      },
      "data_range": {
        "type": "string"
      },
      "total_steps": {
        "type": "integer",
        "description": "Total evaluation steps attempted (including ranging and errors)"
      }
    },
    "decision": {
      "type": "string",
      "enum": ["accepted", "rejected"]
    },
    "rejection_reasons": {
      "type": "array",
      "items": "string",
      "description": "Empty list on accepted iterations"
    },
    "accuracy_before": {
      "type": "float"
    },
    "accuracy_after": {
      "type": "float"
    },
    "accuracy_delta": {
      "type": "float"
    },
    "agent_reasoning": {
      "type": "string",
      "description": "Brief rationale for the proposed change"
    }
  }
}
